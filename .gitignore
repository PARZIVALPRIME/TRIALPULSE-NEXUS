# =============================================================================
# TRIALPULSE NEXUS 10X - Git Ignore Configuration
# =============================================================================

# Virtual environment
venv/
.venv/
env/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# IDE
.vscode/
.idea/
*.swp
*.swo

# =============================================================================
# DATA FILES - Keep raw, exclude processed (too large for GitHub)
# =============================================================================

# Processed data directories (generated by pipelines)
data/processed/
data/outputs/
data/upr/
data/cleaned/

# KEEP raw data - explicitly un-ignore
!data/raw/
!data/raw/**

# Databases (will be regenerated)
*.db

# Logs
*.log
logs/

# Environment (contains API keys)
.env
.env.local
.streamlit/secrets.toml

# OS
.DS_Store
Thumbs.db

# Jupyter
.ipynb_checkpoints/

# Models (large, will be regenerated)
models/

# Knowledge base (generated embeddings)
knowledge_base/

# Temp
tmp/
temp/
*.tmp
*.bak

# Test outputs
test_outputs/
.pytest_cache/
.coverage
htmlcov/
